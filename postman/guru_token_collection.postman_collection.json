{
  "info": {
    "name": "Fun AR - Guru (Token)",
    "_postman_id": "8f3c2c2b-3e4b-4e6a-9e86-5c0f5c1a6b8a",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Generate Soal (SSE)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{token}}\",\n  \"topic\": \"{{topic}}\",\n  \"difficulty\": 1\n}"
        },
        "url": "{{baseUrl}}/soal/buatsoal"
      }
    },
    {
      "name": "Get Nilai (All by Token)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/ujian/nilai?token={{token}}"
      }
    },
    {
      "name": "Get Nilai by User ID (Token)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/ujian/nilai/{{userId}}?token={{token}}"
      }
    },
    {
      "name": "Get Nilai by Nama (Token)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/ujian/nilai/nama/{{nama}}?token={{token}}"
      }
    },
    {
      "name": "Get Detail Nilai (per Sesi)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ujian/nilai/detail/{{sessionId}}?token={{token}}",
          "host": ["{{baseUrl}}"],
          "path": ["ujian", "nilai", "detail", "{{sessionId}}"],
          "query": [
            {
              "key": "token",
              "value": "{{token}}",
              "description": "Token sekolah (6 digit)"
            }
          ]
        },
        "description": "Menampilkan detail lengkap per sesi ujian:\n- Setiap soal yang didapatkan user\n- Jawaban yang dipilih user + teksnya\n- Apakah jawaban benar atau salah\n- Jawaban benar (label + teks)\n- Waktu berpikir per soal\n- Statistik: total benar, salah, akurasi %"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": "123456"
    },
    {
      "key": "topic",
      "value": "aritmatika"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "nama",
      "value": "budi"
    },
    {
      "key": "sessionId",
      "value": "1"
    }
  ]
}
