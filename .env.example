# ===================================
# Environment Variables Template
# Copy file ini jadi .env lalu isi nilainya
# ===================================

# --- Mode Aplikasi ---
# Set "true" untuk development (aktifkan dev-login, SQL echo, dll)
# Set "false" untuk production
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql://username:password@localhost:5432/math_app_db

# --- Google OAuth ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# --- JWT Secret ---
SECRET_KEY=ganti_dengan_random_string_yang_panjang_dan_aman

# --- OpenRouter AI ---
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Site Info ---
YOUR_SITE_URL=https://yourdomain.com
YOUR_SITE_NAME=Your App Name

# --- CORS (comma-separated origins, atau * untuk allow all) ---
ALLOWED_ORIGINS=*
